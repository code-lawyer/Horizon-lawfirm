{
  "ai": {
    "provider": "openai",
    "base_url": "https://openrouter.ai/api/v1",
    "model": "deepseek/deepseek-v4-flash",
    "api_key_env": "OPENROUTER_API_KEY",
    "languages": ["zh"],
    "analysis_concurrency": 4,
    "throttle_sec": 0
  },
  "sources": {
    "hackernews": { "enabled": true, "fetch_top_stories": 30, "min_score": 100 },
    "rss": [
      { "name": "Ars Technica", "url": "https://feeds.arstechnica.com/arstechnica/index", "enabled": true, "category": "tech" },
      { "name": "The Verge", "url": "https://www.theverge.com/rss/index.xml", "enabled": true, "category": "tech" },
      { "name": "Simon Willison", "url": "https://simonwillison.net/atom/everything/", "enabled": true, "category": "ai-ml" }
    ],
    "reddit": {
      "enabled": true,
      "fetch_comments": 5,
      "subreddits": [
        { "subreddit": "MachineLearning", "sort": "hot", "fetch_limit": 25, "min_score": 20 },
        { "subreddit": "programming", "sort": "hot", "fetch_limit": 25, "min_score": 50 }
      ]
    },
    "twitter": { "enabled": false, "users": ["karpathy", "ylecun"], "fetch_limit": 100 }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24,
    "max_items": 15
  },
  "email": { "enabled": false },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "platform": "generic",
    "layout": "markdown",
    "languages": ["zh"],
    "request_body": {
      "date": "#{date}",
      "result": "#{result}",
      "title": "#{message_title}",
      "summary": "#{summary}"
    },
    "headers": "Authorization: Bearer ${INGEST_TOKEN}"
  }
}
